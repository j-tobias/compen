# Backend API URL seen by the browser (baked into the frontend image at build time)
# Set this to your server's public IP or domain before running docker compose build
NEXT_PUBLIC_API_URL=http://malve:8000

# Comma-separated list of origins the backend allows (must match the frontend URL)
CORS_ORIGINS=http://malve:3000

# LLM configuration
LLM_BASE_URL=http://malve:4100/v1
LLM_MODEL=Gemma4-26B
LLM_API_KEY=
